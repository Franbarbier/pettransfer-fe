NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Microsoft Graph / Outlook OAuth (app registration en Microsoft Entra)
# Para desarrollo local, registrar el redirect URI:
# http://localhost:3000/api/microsoft/oauth/callback
MICROSOFT_TENANT_ID=common
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Dropbox API (subida de PDFs de cotizaciones)
# Recomendado: app con offline access + refresh token
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_QUOTES_FOLDER=/Cotizaciones

# OAuth client tipo "Web" en Google Cloud Console → credenciales
# (en Vite era VITE_GOOGLE_CLIENT_ID; acá es NEXT_PUBLIC_*)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Opcional: listar solo hijos de esta carpeta (shared drive / carpetas compartidas)
# NEXT_PUBLIC_GOOGLE_DRIVE_FOLDER_ID=
