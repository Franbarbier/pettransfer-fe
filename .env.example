NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# OAuth client tipo "Web" en Google Cloud Console → credenciales
# (en Vite era VITE_GOOGLE_CLIENT_ID; acá es NEXT_PUBLIC_*)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Opcional: listar solo hijos de esta carpeta (shared drive / carpetas compartidas)
# NEXT_PUBLIC_GOOGLE_DRIVE_FOLDER_ID=
